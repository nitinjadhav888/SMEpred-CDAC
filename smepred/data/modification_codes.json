    { "match": "2-fluoro",               "symbol": "F", "note": "2'-Fluoro (incl. -3'-PS combos)" },
    { "match": "2-deoxy",                "symbol": "D", "note": "2'-Deoxy / DNA (incl. -3'-PS)" },
    { "match": "glycol nucleic acid",    "symbol": "8", "note": "GNA" },
    { "match": "threose nucleic acid",   "symbol": "9", "note": "TNA" },
    { "match": "hexitol nucleic acid",   "symbol": "7", "note": "HNA (mapped onto symbol 7)" },
    { "match": "altritol nucleic acid",  "symbol": "Y", "note": "ANA/altritol (mapped onto Y)" },
    { "match": "arabino",                "symbol": "I", "note": "FANA/arabinonucleic" },
    { "match": "methoxyethyl",           "symbol": "E", "note": "2'-MOE (2'-O-methoxyethyl / 2'-methoxyethyl)" },
    { "match": "reverse deoxy",          "symbol": "D", "note": "inverted/reverse deoxy terminal cap" },
    { "match": "2-o-hexadecyl",          "symbol": "X", "note": "2'-O-alkyl/lipophilic" },
    { "match": "2-o-benzyl",             "symbol": "B", "note": "2'-O-benzyl" },
    { "match": "4-thio",                 "symbol": "N", "note": "4'-thio" },
    { "match": "pseudouridine",          "symbol": "W", "note": "pseudouridine" },
    { "match": "methylcytidine",         "symbol": "V", "note": "5-methyl-C" },
    { "match": "inosine",                "symbol": "J", "note": "inosine" },
    { "match": "abasic",                 "symbol": "Q", "note": "abasic / inverted abasic" },
    { "match": "galactosamine",          "symbol": "4", "note": "GalNAc conjugate (n-acetyl(-)galactosamine)" },
    { "match": "galnac",                 "symbol": "4", "note": "GalNAc conjugate" },
